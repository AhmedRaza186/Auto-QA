# AI Test Automation Agent (Auto-QA) example environment variables

# Database connection string for Drizzle
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# GitHub OAuth application credentials
CLIENT_ID=your_github_oauth_client_id
CLIENT_SECRET=your_github_oauth_client_secret
REDIRECT_URI=http://localhost:3000/api/github/callback

# Google Gemini AI
GEMINI_API_KEY=your_google_gemini_api_key

# Stripe configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER=price_1234567890abcdef

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
# NODE_ENV=development
# NEXT_PUBLIC_VERCEL_URL=your-vercel-url
